# PostgreSQL connection string
# Local:  postgresql://<user>:<password>@localhost:5432/todo_app
# Cloud:  get this from Neon / Supabase / Railway after creating a free project
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/todo_app

# JWT Secret for token signing (use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-random-secret-key-here>

# JWT Token expiration time
JWT_EXPIRATION=30d

# Server port
PORT=3000

# Environment (development, test, production)
NODE_ENV=development
